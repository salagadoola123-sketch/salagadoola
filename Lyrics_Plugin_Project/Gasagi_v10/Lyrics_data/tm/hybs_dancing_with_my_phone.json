  "lyrics": [
    { "id":  1, "section": "verse1", "type": "sung", "text": "I'm just laying on the floor again", "translation": "난 그냥 또 바닥에 누워있어", "translation_notes": "또 바닥에 누워있다. 무기력한 일상 반복", "relation": {"type": "setup_chain", "group": "v1a", "role": "anchor", "ref": [1, 2], "auto_hints": []} },
    { "id":  2, "section": "verse1", "type": "sung", "text": "Can't be bothered to get up now", "translation": "지금 일어나긴 너무 귀찮아", "translation_notes": "can't be bothered = 귀찮아서 못 하겠다. 영국식 구어체", "relation": {"type": "setup_chain", "group": "v1a", "role": "continuation", "ref": [1, 2], "auto_hints": []} },
    { "id":  3, "section": "verse1", "type": "sung", "text": "I wouldn't care", "translation": "아무도 신경 안 쓸 거", "translation_notes": "", "relation": {"type": "setup_payoff", "group": "v1b", "role": "setup", "ref": [3, 4], "auto_hints": ["fragment"]} },
    { "id":  4, "section": "verse1", "type": "sung", "text": "If I never get up again", "translation": "내가 다시 일어나지 못한다고 해도", "translation_notes": "다시는 일어나지 않아도 상관없다. 이별 후 무기력 극단", "relation": {"type": "setup_payoff", "group": "v1b", "role": "payoff", "ref": [3, 4], "auto_hints": ["starts_with_relative"]} },
    { "id":  5, "section": "verse1", "type": "sung", "text": "I don't want to", "translation": "그러고 싶지 않아", "translation_notes": "", "relation": {"type": "payoff", "group": "v1c", "role": "pivot", "ref": [5], "auto_hints": []} },
    { "id":  6, "section": "prechorus", "type": "sung", "text": "Then our song comes on the radio", "translation": "그때 우리 노래가 라디오에서 흘러나와", "translation_notes": "our song = 둘만의 노래. 라디오에서 흘러나옴", "relation": {"type": "cause_effect", "group": "pc_a", "role": "cause", "ref": [6, 7], "auto_hints": []} },
    { "id":  7, "section": "prechorus", "type": "sung", "text": "Makes me wanna start to dance", "translation": "나를 춤추고 싶게 만들어", "translation_notes": "무기력하다가 노래 듣고 춤추고 싶어짐. 감정 전환점", "relation": {"type": "cause_effect", "group": "pc_a", "role": "effect", "ref": [6, 7], "auto_hints": ["fragment"]} },
    { "id":  8, "section": "prechorus", "type": "sung", "text": "Oh, I wanna know", "translation": "알고 싶어", "translation_notes": "", "relation": {"type": "setup_chain", "group": "pc_b", "role": "anchor", "ref": [8, 9, 10], "auto_hints": ["fragment"]} },
    { "id":  9, "section": "prechorus", "type": "sung", "text": "If you feel the same way as me", "translation": "너도 만약 나와 같은 기분이라면", "translation_notes": "상대도 같은 감정인지 궁금함", "relation": {"type": "setup_chain", "group": "pc_b", "role": "condition", "ref": [8, 9, 10], "auto_hints": ["starts_with_relative"]} },
    { "id": 10, "section": "prechorus", "type": "sung", "text": "Why would you go?", "translation": "왜 떠나고 싶어 하는 걸까", "translation_notes": "왜 떠났냐는 자문. 답 없는 질문", "relation": {"type": "setup_chain", "group": "pc_b", "role": "payoff", "ref": [8, 9, 10], "auto_hints": ["fragment"]} },
    { "id": 11, "section": "chorus", "type": "sung", "text": "Dancing, I'm all alone", "translation": "혼자 춤을 춰", "translation_notes": "혼자 춤추고 있다. 제목과 연결", "relation": {"type": "setup_chain", "group": "ch_a", "role": "anchor", "ref": [11, 12], "auto_hints": ["no_subject", "fragment"]} },
    { "id": 12, "section": "chorus", "type": "sung", "text": "Figuring out how I can get you home", "translation": "어떻게 하면 너를 다시 내 곁에 데려올 수 있을지 생각하면서", "translation_notes": "figure out = 방법을 찾다. 어떻게 하면 다시 데려올 수 있을지", "relation": {"type": "setup_chain", "group": "ch_a", "role": "continuation", "ref": [11, 12], "auto_hints": []} },
    { "id": 13, "section": "chorus", "type": "sung", "text": "Dancing with my phone", "translation": "널 생각하면서", "translation_notes": "핸드폰을 붙잡고 춤춤. 연락 기다리며", "relation": {"type": "parallel", "group": "ch_b", "role": "echo", "ref": [13, 14], "auto_hints": ["no_subject", "fragment"]} },
    { "id": 14, "section": "chorus", "type": "sung", "text": "Thinking about you", "translation": "널 생각하면서", "translation_notes": "", "relation": {"type": "parallel", "group": "ch_b", "role": "echo", "ref": [13, 14], "auto_hints": ["no_subject", "fragment"]} },
    { "id": 15, "section": "verse2", "type": "sung", "text": "On my feet and now I'm out the door", "translation": "난 이제 일어나 문 밖으로 걸어나왔어", "translation_notes": "on my feet = 일어서서. 결국 밖으로 나감", "relation": {"type": "setup_chain", "group": "v2a", "role": "anchor", "ref": [15, 16], "auto_hints": []} },
    { "id": 16, "section": "verse2", "type": "sung", "text": "Walking by the places that we used to go", "translation": "우리가 갔던 장소들을 지나치면서", "translation_notes": "우리가 자주 가던 곳들을 걸어다님", "relation": {"type": "setup_chain", "group": "v2a", "role": "continuation", "ref": [15, 16], "auto_hints": []} },
    { "id": 17, "section": "verse2", "type": "sung", "text": "I remember all your favorite stores", "translation": "네가 좋아하는 가게들을 모두 기억해", "translation_notes": "상대가 좋아하던 가게들을 기억함. 사소한 것까지", "relation": {"type": "continuation", "group": "v2b", "role": "anchor", "ref": [17, 18], "auto_hints": []} },
    { "id": 18, "section": "verse2", "type": "sung", "text": "I won't lie", "translation": "거짓말 아니야", "translation_notes": "솔직하게 말하자면", "relation": {"type": "continuation", "group": "v2b", "role": "continuation", "ref": [17, 18], "auto_hints": ["fragment"]} },
    { "id": 19, "section": "verse2", "type": "sung", "text": "I don't think I even know myself anymore", "translation": "나 자신조차 모르는 것 같아, 더 이상은", "translation_notes": "이별 후 자아를 잃은 상태. 핵심 라인", "relation": {"type": "setup_payoff", "group": "v2c", "role": "setup", "ref": [19, 20, 21], "auto_hints": []} },
    { "id": 20, "section": "verse2", "type": "sung", "text": "You're the one who knew me fuckin' well", "translation": "너야말로 나를 잘 아는 사람이니까", "translation_notes": "fuckin' = 강조. 나를 가장 잘 알았던 사람", "relation": {"type": "setup_payoff", "group": "v2c", "role": "cause", "ref": [19, 20, 21], "auto_hints": ["starts_with_conjunction"]} },
