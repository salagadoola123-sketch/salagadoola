    { "id":  9, "section": "verse1", "type": "sung", "text": "I just wanna know if you'd be down too", "translation": "너도 같은 마음인지 알고 싶어", "translation_notes": "be down = 동의하다, 함께하고 싶다", "relation": {"type": "contrast", "group": "v1c", "role": "payoff", "ref": [8, 9], "auto_hints": []} },
    { "id": 10, "section": "prechorus1", "type": "sung", "text": "So I need to know", "translation": "그래서 알아야 해", "translation_notes": "", "relation": {"type": "setup_payoff", "group": "pc1a", "role": "setup", "ref": [10, 11], "auto_hints": ["starts_with_conjunction"]} },
