    { "id":  5, "section": "verse1", "type": "sung", "text": "If it means that I'm going home alone", "translation": "혼자 집에 가는 거라면", "translation_notes": "", "relation": {"type": "setup_chain", "group": "v1a", "role": "condition", "ref": [4, 5], "auto_hints": ["starts_with_relative"]} },
    { "id":  6, "section": "verse1", "type": "sung", "text": "I need someone to hold me down, yeah", "translation": "날 붙잡아줄 사람이 필요해", "translation_notes": "hold down = 붙잡다, 안정감을 주다", "relation": {"type": "setup_payoff", "group": "v1b", "role": "setup", "ref": [6, 7], "auto_hints": []} },
    { "id":  7, "section": "verse1", "type": "sung", "text": "Like I'd treat you if you let me, yeah", "translation": "내가 해줄 수 있는 것처럼", "translation_notes": "", "relation": {"type": "setup_payoff", "group": "v1b", "role": "payoff", "ref": [6, 7], "auto_hints": []} },
