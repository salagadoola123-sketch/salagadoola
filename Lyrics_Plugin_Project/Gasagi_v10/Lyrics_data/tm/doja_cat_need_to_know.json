    { "id": 16, "section": "verse2", "type": "sung", "text": "You say you been feeling lonely", "translation": "외로웠다고 했잖아", "translation_notes": "", "relation": {"type": "setup_chain", "group": "v2a", "role": "anchor", "ref": [16, 17], "auto_hints": []} },
