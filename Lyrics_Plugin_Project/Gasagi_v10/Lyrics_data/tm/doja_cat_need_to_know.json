    { "id": 12, "section": "chorus1", "type": "sung", "text": "Do you want me? Do you want me? Do you want me?", "translation": "날 원해? 날 원해? 날 원해?", "translation_notes": "", "relation": {"type": "parallel", "group": "ch_a", "role": "echo", "ref": [12], "auto_hints": []} },
