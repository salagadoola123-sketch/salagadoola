  "lyrics": [
    { "id":  1, "section": "verse1", "type": "sung", "text": "I got my driver's license last week", "translation": "지난주에 드디어 운전면허를 땄어", "translation_notes": "곡 전체의 출발점. 기쁜 사건이지만 맥락상 쓸쓸함", "relation": {"type": "setup_chain", "group": "v1a", "role": "anchor", "ref": [1, 2, 3, 4], "auto_hints": []} },
    { "id":  2, "section": "verse1", "type": "sung", "text": "Just like we always talked about", "translation": "우리가 항상 얘기하던 것처럼", "translation_notes": "과거 함께 꿈꾸던 계획을 혼자 이뤘다는 아이러니", "relation": {"type": "setup_chain", "group": "v1a", "role": "background", "ref": [1, 2, 3, 4], "auto_hints": ["starts_with_relative"]} },
    { "id":  3, "section": "verse1", "type": "sung", "text": "'Cause you were so excited for me", "translation": "네가 나 대신 그렇게 설레했잖아", "translation_notes": "", "relation": {"type": "setup_chain", "group": "v1a", "role": "background", "ref": [1, 2, 3, 4], "auto_hints": ["starts_with_conjunction"]} },
    { "id":  4, "section": "verse1", "type": "sung", "text": "To finally drive up to your house", "translation": "드디어 네 집까지 운전해 가려고", "translation_notes": "", "relation": {"type": "setup_chain", "group": "v1a", "role": "purpose", "ref": [1, 2, 3, 4], "auto_hints": ["no_subject"]} },
    { "id":  5, "section": "verse1", "type": "sung", "text": "But today I drove through the suburbs", "translation": "그런데 오늘 나 혼자 그 동네를 달렸어", "translation_notes": "", "relation": {"type": "cause_effect", "group": "v1b", "role": "cause", "ref": [5, 6], "auto_hints": ["starts_with_conjunction"]} },
    { "id":  6, "section": "verse1", "type": "sung", "text": "Crying 'cause you weren't around", "translation": "네가 없어서 울면서", "translation_notes": "", "relation": {"type": "cause_effect", "group": "v1b", "role": "effect", "ref": [5, 6], "auto_hints": ["no_subject"]} },
    { "id":  7, "section": "verse1", "type": "sung", "text": "And you didn't even notice when I drove past your house", "translation": "내가 네 집 앞을 지나쳐도 넌 알아채지도 못했지", "translation_notes": "", "relation": {"type": "payoff", "group": "v1c", "role": "payoff", "ref": [1, 2, 3, 4, 5, 6, 7], "auto_hints": ["starts_with_conjunction"]} },
    { "id":  8, "section": "prechorus1", "type": "sung", "text": "I don't know what to do with all this driving", "translation": "이 모든 드라이브로 뭘 해야 할지 모르겠어", "translation_notes": "", "relation": {"type": "setup_chain", "group": "pc1a", "role": "anchor", "ref": [8, 9, 10], "auto_hints": []} },
    { "id":  9, "section": "prechorus1", "type": "sung", "text": "I just ride and ride and ride", "translation": "그냥 달리고 달리고 또 달려", "translation_notes": "", "relation": {"type": "setup_chain", "group": "pc1a", "role": "continuation", "ref": [8, 9, 10], "auto_hints": []} },
    { "id": 10, "section": "prechorus1", "type": "sung", "text": "Guess I'll just cruise", "translation": "그냥 드라이브나 하는 수밖에", "translation_notes": "cruise = 목적 없이 느긋하게 달리다", "relation": {"type": "setup_chain", "group": "pc1a", "role": "resolution", "ref": [8, 9, 10], "auto_hints": []} },
    { "id": 11, "section": "chorus1", "type": "sung", "text": "Red lights, stop signs", "translation": "빨간 신호등, 정지 표지판", "translation_notes": "멈춰야 하는 것들 → 감정도 멈추지 못하는 아이러니", "relation": {"type": "parallel", "group": "ch1a", "role": "image", "ref": [11, 12, 13, 14], "auto_hints": ["fragment"]} },
    { "id": 12, "section": "chorus1", "type": "sung", "text": "I still see your face in the white cars", "translation": "흰 차들 사이에서 아직도 네 얼굴이 보여", "translation_notes": "", "relation": {"type": "parallel", "group": "ch1a", "role": "emotion", "ref": [11, 12, 13, 14], "auto_hints": []} },
    { "id": 13, "section": "chorus1", "type": "sung", "text": "Front lawns in the suburbs", "translation": "교외 주택가 앞마당들", "translation_notes": "", "relation": {"type": "parallel", "group": "ch1a", "role": "image", "ref": [11, 12, 13, 14], "auto_hints": ["fragment"]} },
    { "id": 14, "section": "chorus1", "type": "sung", "text": "I still hear your voice in the traffic", "translation": "차 막히는 소리 속에서 아직도 네 목소리가 들려", "translation_notes": "", "relation": {"type": "parallel", "group": "ch1a", "role": "emotion", "ref": [11, 12, 13, 14], "auto_hints": []} },
    { "id": 15, "section": "chorus1", "type": "sung", "text": "We used to talk every night", "translation": "우리 매일 밤 통화했었잖아", "translation_notes": "", "relation": {"type": "setup_payoff", "group": "ch1b", "role": "setup", "ref": [15, 16, 17], "auto_hints": []} },
    { "id": 16, "section": "chorus1", "type": "sung", "text": "And I don't wanna be without you", "translation": "너 없이는 살고 싶지 않아", "translation_notes": "", "relation": {"type": "setup_payoff", "group": "ch1b", "role": "tension", "ref": [15, 16, 17], "auto_hints": ["starts_with_conjunction"]} },
    { "id": 17, "section": "chorus1", "type": "sung", "text": "But God, I hate it when you make me feel like that", "translation": "근데 이런 기분 들게 하는 네가 진짜 미워", "translation_notes": "God = 감탄/강조. 사랑과 원망이 공존", "relation": {"type": "setup_payoff", "group": "ch1b", "role": "payoff", "ref": [15, 16, 17], "auto_hints": ["starts_with_conjunction"]} },
    { "id": 18, "section": "verse2", "type": "sung", "text": "I still remember the first time we kissed", "translation": "처음 키스했던 순간, 아직도 생생해", "translation_notes": "", "relation": {"type": "continuation", "group": "v2a", "role": "anchor", "ref": [18, 19], "auto_hints": []} },
    { "id": 19, "section": "verse2", "type": "sung", "text": "And you were smiling and I felt it too", "translation": "네가 웃고 있었고, 나도 그 감정이 느껴졌지", "translation_notes": "", "relation": {"type": "continuation", "group": "v2a", "role": "continuation", "ref": [18, 19], "auto_hints": ["starts_with_conjunction"]} },
    { "id": 20, "section": "verse2", "type": "sung", "text": "And all my friends say that I'm better off without you", "translation": "친구들은 전부 네 없이 잘 살 거라 하지만", "translation_notes": "", "relation": {"type": "contrast", "group": "v2b", "role": "claim", "ref": [20, 21], "auto_hints": ["starts_with_conjunction"]} },
    { "id": 21, "section": "verse2", "type": "sung", "text": "But they don't feel the way I do", "translation": "내 마음이 어떤지 걔네는 모르잖아", "translation_notes": "", "relation": {"type": "contrast", "group": "v2b", "role": "rebuttal", "ref": [20, 21], "auto_hints": ["starts_with_conjunction"]} },
    { "id": 22, "section": "verse2", "type": "sung", "text": "I still fucking love you, babe", "translation": "나 아직도 진짜 사랑해, 자기야", "translation_notes": "fucking = 억누를 수 없는 감정 강조. 검열 없는 솔직함", "relation": {"type": "continuation", "group": "v2c", "role": "anchor", "ref": [22, 23], "auto_hints": []} },
    { "id": 23, "section": "verse2", "type": "sung", "text": "And I don't wanna give that up", "translation": "이 감정 포기하고 싶지 않아", "translation_notes": "", "relation": {"type": "continuation", "group": "v2c", "role": "continuation", "ref": [22, 23], "auto_hints": ["starts_with_conjunction"]} },
    { "id": 24, "section": "prechorus2", "type": "sung", "text": "And I know you're with her", "translation": "걔랑 있다는 거 알아", "translation_notes": "제3자 등장. 삼각관계 암시", "relation": {"type": "concession_claim", "group": "pc2a", "role": "concession", "ref": [24, 25, 26], "auto_hints": ["starts_with_conjunction"]} },
    { "id": 25, "section": "prechorus2", "type": "sung", "text": "But I still can't stop you from being in my head", "translation": "그래도 머릿속에서 네가 안 사라져", "translation_notes": "", "relation": {"type": "concession_claim", "group": "pc2a", "role": "obstacle", "ref": [24, 25, 26], "auto_hints": ["starts_with_conjunction"]} },
    { "id": 26, "section": "prechorus2", "type": "sung", "text": "She doesn't love you like I love you", "translation": "걔가 나처럼 널 사랑하진 않아", "translation_notes": "직접적 비교. 감정의 격렬함", "relation": {"type": "concession_claim", "group": "pc2a", "role": "claim", "ref": [24, 25, 26], "auto_hints": []} },
    { "id": 27, "section": "chorus2", "type": "sung", "text": "Red lights, stop signs", "translation": "빨간 신호등, 정지 표지판", "translation_notes": "", "relation": {"type": "parallel", "group": "ch2a", "role": "image", "ref": [27, 28, 29, 30], "auto_hints": ["fragment"]} },
