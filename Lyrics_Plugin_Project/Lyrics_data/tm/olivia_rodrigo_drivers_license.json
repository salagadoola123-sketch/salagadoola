    { "id": 31, "section": "chorus2", "type": "sung", "text": "We used to talk every night", "translation": "우리 매일 밤 통화했었잖아", "translation_notes": "", "relation": {"type": "setup_payoff", "group": "ch2b", "role": "setup", "ref": [31, 32, 33], "auto_hints": []} },
