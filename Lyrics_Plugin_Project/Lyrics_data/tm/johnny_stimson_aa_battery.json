  "lyrics": [
    { "id":  1, "section": "verse1", "type": "sung", "speaker": "Johnny", "text": "When you're running out of juice", "translation": "배터리가 다 떨어지면", "translation_notes": "juice = 배터리 잔량/에너지. 상대방이 지쳐있을 때", "relation": {"type": "setup_chain", "group": "v1a", "role": "anchor", "ref": [1, 2], "auto_hints": ["starts_with_relative", "fragment"]} },
    { "id":  2, "section": "verse1", "type": "sung", "speaker": "Johnny", "text": "Plug me in and cut me loose", "translation": "날 꽂아서 전원을 켜", "translation_notes": "plug me in = 나를 연결해. cut me loose = 자유롭게 풀어줘. 원문 번역 오류 수정", "relation": {"type": "setup_chain", "group": "v1a", "role": "payoff", "ref": [1, 2], "auto_hints": []} },
    { "id":  3, "section": "verse1", "type": "sung", "speaker": "Johnny", "text": "I know exactly what to do", "translation": "뭘 해야 할지 난 정확히 알아", "translation_notes": "", "relation": {"type": "continuation", "group": "v1b", "role": "anchor", "ref": [3, 4], "auto_hints": []} },
    { "id":  4, "section": "verse1", "type": "sung", "speaker": "Johnny", "text": "You can count on me", "translation": "날 믿어도 돼", "translation_notes": "count on = 의지하다/믿다", "relation": {"type": "continuation", "group": "v1b", "role": "continuation", "ref": [3, 4], "auto_hints": []} },
    { "id":  5, "section": "verse2", "type": "sung", "speaker": "Johnny", "text": "Chemical reaction starts", "translation": "화학반응이 일어나고", "translation_notes": "사랑의 감정을 화학반응으로 비유", "relation": {"type": "setup_chain", "group": "v2a", "role": "anchor", "ref": [5, 6], "auto_hints": ["fragment"]} },
    { "id":  6, "section": "verse2", "type": "sung", "speaker": "Johnny", "text": "You were glowing in the dark", "translation": "넌 어둠 속에서 빛나고 있었지", "translation_notes": "glowing = 빛나다. 형광 배터리 이미지", "relation": {"type": "setup_chain", "group": "v2a", "role": "continuation", "ref": [5, 6], "auto_hints": []} },
    { "id":  7, "section": "verse2", "type": "sung", "speaker": "Johnny", "text": "Shockwave in my heart", "translation": "내 심장이 충격을 받았어", "translation_notes": "shockwave = 충격파. 전기충격 + 심장두근거림 이중 의미", "relation": {"type": "cause_effect", "group": "v2b", "role": "cause", "ref": [7, 8], "auto_hints": ["fragment"]} },
    { "id":  8, "section": "verse2", "type": "sung", "speaker": "Johnny", "text": "Electricity", "translation": "짜릿했지", "translation_notes": "전기 = 설렘의 은유", "relation": {"type": "cause_effect", "group": "v2b", "role": "effect", "ref": [7, 8], "auto_hints": ["fragment"]} },
    { "id":  9, "section": "bridge", "type": "sung", "speaker": "Johnny", "text": "You pull me in like a magnet", "translation": "넌 마치 자석처럼 날 끌어당겨", "translation_notes": "magnet = 자석. 물리적 인력으로 사랑 표현", "relation": {"type": "setup_chain", "group": "ch_a", "role": "anchor", "ref": [9, 10, 11], "auto_hints": []} },
    { "id": 10, "section": "chorus", "type": "sung", "speaker": "Johnny", "text": "Keep giving that good energy", "translation": "계속 그렇게 좋은 에너지를 줘", "translation_notes": "", "relation": {"type": "setup_chain", "group": "ch_a", "role": "continuation", "ref": [9, 10, 11], "auto_hints": []} },
    { "id": 11, "section": "chorus", "type": "sung", "speaker": "Johnny", "text": "On and on to infinity baby", "translation": "끊임없이 무한대로", "translation_notes": "", "relation": {"type": "setup_chain", "group": "ch_a", "role": "continuation", "ref": [9, 10, 11], "auto_hints": ["fragment"]} },
    { "id": 12, "section": "chorus", "type": "sung", "speaker": "Johnny", "text": "Good chemistry", "translation": "우린 케미가 좋아", "translation_notes": "chemistry = 화학 + 두 사람 사이의 케미 이중의미", "relation": {"type": "parallel", "group": "ch_b", "role": "image", "ref": [12, 13, 14], "auto_hints": []} },
    { "id": 13, "section": "chorus", "type": "sung", "speaker": "Johnny", "text": "Living it up with the love that you're giving me", "translation": "난 네가 주는 사랑으로 살아", "translation_notes": "living it up = 인생을 즐기다", "relation": {"type": "parallel", "group": "ch_b", "role": "image", "ref": [12, 13, 14], "auto_hints": []} },
    { "id": 14, "section": "chorus", "type": "sung", "speaker": "Johnny", "text": "Good synchronicity", "translation": "우린 잘 맞아", "translation_notes": "synchronicity = 동시성/싱크로율", "relation": {"type": "parallel", "group": "ch_b", "role": "image", "ref": [12, 13, 14], "auto_hints": []} },
    { "id": 15, "section": "chorus", "type": "sung", "speaker": "Johnny", "text": "Fire me up I'm your double a battery", "translation": "날 타오르게 해줘, 난 너의 AA 배터리야", "translation_notes": "fire me up = 불을 붙이다/활기차게 하다. double a = AA 배터리", "relation": {"type": "setup_payoff", "group": "ch_c", "role": "setup", "ref": [15, 16], "auto_hints": []} },
    { "id": 16, "section": "chorus", "type": "sung", "speaker": "Johnny", "text": "100 degrees and I'm ready to go all night", "translation": "100도가 되고, 난 밤새 갈 준비가 됐어", "translation_notes": "100도 = 최고 온도/최고 에너지 상태", "relation": {"type": "setup_payoff", "group": "ch_c", "role": "payoff", "ref": [15, 16], "auto_hints": []} },
    { "id": 17, "section": "interlude", "type": "sung", "speaker": "Johnny", "text": "Number 5", "translation": "넘버 5", "translation_notes": "AA 배터리 사이즈 넘버. 또는 완벽함의 상징" },
    { "id": 18, "section": "interlude", "type": "sung", "speaker": "Johnny", "text": "Feeling fine", "translation": "기분이 좋아", "translation_notes": "" },
    { "id": 19, "section": "verse3", "type": "sung", "speaker": "JORDANN", "text": "Et quand je manque d'énergie", "translation": "내 에너지가 다해갈 때", "translation_notes": "프랑스어. '그리고 내가 에너지가 부족할 때'", "relation": {"type": "setup_chain", "group": "v3a", "role": "anchor", "ref": [19, 20, 21], "auto_hints": ["starts_with_relative"]} },
    { "id": 20, "section": "verse3", "type": "sung", "speaker": "JORDANN", "text": "Un moment de synergie", "translation": "우리가 시너지를 만들어내는 그 순간이", "translation_notes": "프랑스어. '시너지의 한 순간'", "relation": {"type": "setup_chain", "group": "v3a", "role": "continuation", "ref": [19, 20, 21], "auto_hints": ["fragment"]} },
    { "id": 21, "section": "verse3", "type": "sung", "speaker": "JORDANN", "text": "Repolarise mes esprits une décennie", "translation": "10년은 가도록 내 영혼을 재충전해줘", "translation_notes": "프랑스어. repolarise = 재극성화/재충전. esprits = 정신/영혼. décennie = 10년", "relation": {"type": "setup_chain", "group": "v3a", "role": "payoff", "ref": [19, 20, 21], "auto_hints": []} },
    { "id": 22, "section": "verse4", "type": "sung", "speaker": "JORDANN", "text": "I'm positive I can energize your days with connectivity", "translation": "확신해, 우리가 연결되면 네 하루가 에너지 넘칠 거야", "translation_notes": "positive = 확신 + 배터리 양극(+) 이중의미. connectivity = 연결성", "relation": {"type": "cause_effect", "group": "v4a", "role": "cause", "ref": [22, 23], "auto_hints": []} },
    { "id": 23, "section": "verse4", "type": "sung", "speaker": "JORDANN", "text": "I wanna give it a shake and see if this current's what we need", "translation": "우리가 필요한 게 이 전류인지 확인해 보고 싶어", "translation_notes": "shake = 배터리를 흔들다. current = 전류 + 현재 이중의미", "relation": {"type": "cause_effect", "group": "v4a", "role": "continuation", "ref": [22, 23], "auto_hints": []} },
    { "id": 24, "section": "verse4", "type": "sung", "speaker": "JORDANN", "text": "Qu'on passe d'aimants à amants", "translation": "자석 같은 끌림을 지나 연인이 되기를", "translation_notes": "프랑스어. aimants = 자석들. amants = 연인들. 발음 유사한 말장난", "relation": {"type": "setup_payoff", "group": "v4b", "role": "setup", "ref": [24], "auto_hints": []} },
